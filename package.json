{
  "name": "brainbox-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "install:all": "pnpm install",
    "prepare": "husky",
    "kg:update": "tsx scripts/update-knowledge-graph.ts",
    "brain:search": "tsx scripts/search-brain.ts",
    "stop": "fuser -k 3000/tcp 2>/dev/null || true",
    "rd": "pnpm stop && pnpm dev"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "turbo": "^2.4.4",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "catalog:",
    "eslint-config-next": "catalog:",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.2",
    "tsx": "^4.21.0",
    "typescript": "catalog:",
    "typescript-eslint": "^8.58.1",
    "vitest": "catalog:"
  }
}
