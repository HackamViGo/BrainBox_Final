#!/usr/bin/env sh
# .husky/pre-push
# Преди push: typecheck + unit tests (бърза проверка)
# E2E НЕ се пуска локално — само в CI

echo "⏳ Running pre-push checks..."

# Typecheck на целия монорепо
pnpm typecheck
if [ $? -ne 0 ]; then
  echo "❌ TypeScript errors found. Push aborted."
  exit 1
fi

# Unit тестове (без watch mode)
pnpm run test --run
if [ $? -ne 0 ]; then
  echo "❌ Unit tests failed. Push aborted."
  exit 1
fi

echo "✅ All checks passed."
